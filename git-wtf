from typing import List, Dict, Optional, Tuple, Any


# Exit codes
class ExitCode:
    """Standard exit codes for the application."""
    SUCCESS = 0
    ERROR = 1
    GIT_ERROR = 128


# ANSI color codes
class Color:
    """ANSI color codes for terminal output."""
    RED = '\033[31m'
    GREEN = '\033[32m'
    YELLOW = '\033[33m'
    CYAN = '\033[36m'
    PURPLE = '\033[35m'
    GREY = '\033[1;30m'
    RESET = '\033[0m'


# Git command timeout (seconds)
GIT_TIMEOUT = 30

# Config file name
CONFIG_FN = ".git-wtfrc.json"

# Default configuration
DEFAULT_CONFIG = {
    "integration-branches": ["heads/master", "heads/next", "heads/edge"],
    "ignore": [],
    "max_commits": 5
}


class GitError(Exception):
    """Base exception for git-related errors."""
    pass


class GitRepositoryError(GitError):
    """Raised when not in a valid git repository."""
    pass


class GitCommandError(GitError):
    """Raised when a git command fails."""
    pass


class GitTimeoutError(GitError):
    """Raised when a git command times out."""
    pass


# Global configuration (set during execution)
config: Dict[str, Any] = {}
use_color: bool = False
long: bool = False
short: bool = False
all_remotes: bool = False
all_commits: bool = False
show_filename: bool = False


