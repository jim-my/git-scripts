"""
git-wtf - Display the state of your repository in a readable format

Python port of the original Ruby version by William Morgan.
Original: https://github.com/DanielVartanov/willgit/blob/07e9bfd03e8bf512481bdeb77acec2d8c84b4595/bin/git-wtf

This Python version:
- Zero dependencies (standard library only)
- Maintains same functionality and interface as original
- Uses JSON for config instead of YAML
"""

import subprocess
import sys
import os
import json
