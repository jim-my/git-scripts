def validate_ref_name(name: str) -> str:
    """
    Validate and sanitize a git reference name.

    Args:
        name: The reference name to validate

    Returns:
        The validated name

    Raises:
        ValueError: If the name contains invalid characters
    """
    # Git ref names can contain alphanumeric, dash, underscore, slash, and dot
    if not re.match(r'^[a-zA-Z0-9/_\-\.]+$', name):
        raise ValueError(f"Invalid reference name: {name!r}")
    return name


def pluralize(n: int, s: str) -> str:
    """
    Format number with singular/plural form.

    Args:
        n: The count
        s: The singular form of the word

    Returns:
        Formatted string like "1 commit" or "2 commits"

    Example:
        >>> pluralize(1, 'commit')
        '1 commit'
        >>> pluralize(2, 'commit')
        '2 commits'
    """
    return f"{n} {s}" + ("s" if n != 1 else "")


def find_file(fn: str) -> Optional[str]:
    """
    Search up the directory tree for a file.

    Args:
        fn: Filename to search for

    Returns:
        Absolute path to the file if found, None otherwise

    Example:
        >>> find_file('.git-wtfrc.json')
        '/home/user/project/.git-wtfrc.json'
    """
    current = Path.cwd()
    while True:
        candidate = current / fn
        if candidate.exists():
            return str(candidate)
        parent = current.parent
        if parent == current:  # reached root
            return None
        current = parent


def git_config(key: str) -> str:
    """
    Get a git configuration value.

    Args:
        key: Git config key (e.g., 'color.ui')

    Returns:
        The config value, or empty string if not set

    Example:
        >>> git_config('color.ui')
        'auto'
    """
    try:
        result = subprocess.run(
            ["git", "config", key],
            capture_output=True,
            text=True,
            check=False,
            timeout=GIT_TIMEOUT
        )
        return result.stdout.strip()
    except subprocess.TimeoutExpired:
        return ""
    except Exception:
        return ""


def git_command(cmd: List[str], check: bool = False, timeout: int = GIT_TIMEOUT) -> str:
    """
    Run a git command and return its output.

    Args:
        cmd: Command and arguments as a list
        check: If True, raise GitCommandError on failure
        timeout: Timeout in seconds

    Returns:
        Command stdout stripped of whitespace

    Raises:
        GitRepositoryError: If not in a git repository
        GitCommandError: If command fails and check=True
        GitTimeoutError: If command times out

    Example:
        >>> git_command(['git', 'branch', '--show-current'])
        'main'
    """
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=False,
            shell=False,
            timeout=timeout
        )

        if check and result.returncode != 0:
            if result.returncode == ExitCode.GIT_ERROR:
                if "not a git repository" in result.stderr.lower():
                    raise GitRepositoryError("Not in a git repository")
            raise GitCommandError(f"Git command failed: {result.stderr}")

        return result.stdout.strip()

    except subprocess.TimeoutExpired:
        raise GitTimeoutError(f"Git command timed out: {' '.join(cmd)}")
    except FileNotFoundError:
        raise GitCommandError("Git is not installed or not in PATH")


def colorize(text: str, color: str) -> str:
    """
    Apply ANSI color to text if color output is enabled.

    Args:
        text: Text to colorize
        color: Color code from Color class

    Returns:
        Colored text if use_color is True, otherwise plain text
    """
    if use_color:
        return f"{color}{text}{Color.RESET}"
    return text


def red(s: str) -> str:
    """Apply red color to string."""
    return colorize(s, Color.RED)


def green(s: str) -> str:
    """Apply green color to string."""
    return colorize(s, Color.GREEN)


def yellow(s: str) -> str:
    """Apply yellow color to string."""
    return colorize(s, Color.YELLOW)


def cyan(s: str) -> str:
    """Apply cyan color to string."""
    return colorize(s, Color.CYAN)


def grey(s: str) -> str:
    """Apply grey color to string."""
    return colorize(s, Color.GREY)


def purple(s: str) -> str:
    """Apply purple color to string."""
    return colorize(s, Color.PURPLE)


def get_commits_between(from_ref: str, to_ref: str) -> List[str]:
    """
    Get commits in 'to_ref' that aren't in 'from_ref'.

    Args:
        from_ref: Starting reference (validated)
        to_ref: Ending reference (validated)

    Returns:
        List of formatted commit lines

    Raises:
        ValueError: If ref names are invalid
    """
    # Validate inputs
    validate_ref_name(from_ref)
    validate_ref_name(to_ref)

    if long:
        format_str = f"- <%an> %s [{yellow('%h')}] ({purple('%ae')}; %ar)"
    else:
        format_str = f"- <%an> %s [{yellow('%h')}]"

    cmd = ["git", "log", f"--pretty=format:{format_str}", f"{from_ref}..{to_ref}"]
    output = git_command(cmd)
    return output.split('\n') if output else []


def show_commits(commits: List[str], prefix: str = "    ") -> None:
    """
    Display a list of commits with optional file changes.

    Args:
        commits: List of formatted commit strings
        prefix: Prefix for each line (for indentation)
    """
    if not commits:
        print(f"{prefix} none")
        return

    max_commits = len(commits) if all_commits else config["max_commits"]
    if max_commits == len(commits) - 1:  # never show "and 1 more"
        max_commits -= 1

    for c in commits[:max_commits]:
        print(f"{prefix}{c}")
        if show_filename:
            # Extract commit hash from the commit string
            match = re.search(r'\[([^\]]+)\]', c)
            if match:
                commit_hash = re.sub(r'\x1b\[[\d;]*m', '', match.group(1))  # strip ANSI codes
                try:
                    validate_ref_name(commit_hash)
                    files_output = git_command(["git", "show", "--pretty=format:", "--name-only", commit_hash])
                    files = [f for f in files_output.split('\n') if f]
                    if files:
                        for f in files:
                            print(f"{prefix}\t * {f}")
                except ValueError:
                    pass  # Skip invalid hashes

    if len(commits) > max_commits:
        remaining = len(commits) - max_commits
        print(yellow(f"{prefix}... and {pluralize(remaining, 'commit')} more (use -A to see all)."))


def format_ahead_behind(ahead: List[str], behind: List[str]) -> str:
    """
    Format ahead/behind status as a human-readable string.

    Args:
        ahead: List of commits ahead
        behind: List of commits behind

    Returns:
        Formatted string like "2 commits ahead; 1 commit behind"
    """
    parts = []
    if ahead:
        parts.append(pluralize(len(ahead), 'commit') + ' ahead')
    if behind:
        parts.append(pluralize(len(behind), 'commit') + ' behind')
    return "; ".join(parts)


def print_widget(merged_in: bool, remote_only: bool = False,
                local_only: bool = False, local_only_merge: bool = False) -> None:
    """
    Print a merge status indicator widget.

    Args:
        merged_in: Whether the branch is merged
        remote_only: Branch exists only on remote
        local_only: Branch exists only locally
        local_only_merge: Merged only locally

    Prints:
        A colored bracket indicator like [x], (), or {}
    """
    if remote_only:
        left, right = '{', '}'
    elif local_only:
        left, right = '(', ')'
    else:
        left, right = '[', ']'

    if merged_in and local_only_merge:
        middle = green('~')
    elif merged_in:
        middle = green('x')
    else:
        middle = ' '

    print(left + middle + right, end=' ')


def show_branch_status(branch_info: Dict[str, Any]) -> None:
    """
    Display status for a single branch.

    Args:
        branch_info: Dictionary containing branch information
            Keys: local_branch, remote_branch, remote_url, name
    """
    have_both = branch_info.get('local_branch') and branch_info.get('remote_branch')

    pushc, pullc, oosync = [], [], False
    if have_both:
        pushc = get_commits_between(branch_info['remote_branch'], branch_info['local_branch'])
        pullc = get_commits_between(branch_info['local_branch'], branch_info['remote_branch'])
        oosync = bool(pushc) and bool(pullc)

    # Show local branch status
    if branch_info.get('local_branch'):
        print("Local branch: " + green(branch_info['local_branch'].replace('heads/', '', 1)))

        if have_both:
            if not pushc:
                print_widget(True)
                print("in sync with remote")
            else:
                action = "push after rebase / merge" if oosync else "push"
                print_widget(False)
                print(f"NOT in sync with remote (you should {action})")
                if not short:
                    show_commits(pushc)

    # Show remote branch status
    if branch_info.get('remote_branch'):
        print(f"\nRemote branch: {cyan(branch_info['remote_branch'])} ({branch_info.get('remote_url', '')})")

        if have_both:
            if not pullc:
                print_widget(True)
                print("in sync with local")
            else:
                action = "merge" if not pushc else "rebase / merge"
                print_widget(False)
                print(f"NOT in sync with local (you should {action})")
                if not short:
                    show_commits(pullc)

    if oosync:
        print(f"\n{red('WARNING')}: local and remote branches have diverged. A merge will occur unless you rebase.")


def show_feature_branches(branch_info: Dict[str, Any],
                          feature_branches: List[Tuple[str, Dict[str, Any]]]) -> None:
    """
    Show status of feature branches relative to an integration branch.

    Args:
        branch_info: The integration branch information
        feature_branches: List of (name, branch_info) tuples for feature branches
    """
    if not feature_branches:
        return

    print("\nFeature branches:")
    for name, br in feature_branches:
        if br.get('local_branch') in config["ignore"] or br.get('remote_branch') in config["ignore"]:
            continue
        if br.get('ignore'):
            continue

        local_only = not br.get('remote_branch')
        remote_only = not br.get('local_branch')

        if local_only:
            display_name = purple(br['name'])
        elif remote_only:
            display_name = cyan(br['name'])
        else:
            display_name = green(br['name'])

        head = br['remote_branch'] if remote_only else br['local_branch']

        remote_ahead = get_commits_between(branch_info['remote_branch'], head) if branch_info.get('remote_branch') else []
        local_ahead = get_commits_between(branch_info['local_branch'], head) if branch_info.get('local_branch') else []

        if not local_ahead and not remote_ahead:
            print_widget(True, remote_only, local_only)
            local_only_str = "(local-only) " if local_only else ""
            print(f"{display_name} {local_only_str}is merged in")
        elif not local_ahead:
            print_widget(True, remote_only, local_only, True)
            print(f"{display_name} merged in (only locally)")
        else:
            behind = get_commits_between(head, br.get('local_branch') or br['remote_branch'])
            ahead = remote_ahead if remote_only else local_ahead
            print_widget(False, remote_only, local_only)
            local_only_str = "(local-only) " if local_only else ""
            print(f"{display_name} {local_only_str}is NOT merged in ({format_ahead_behind(ahead, behind)})")
            if not short:
                show_commits(ahead)


def show_integration_branches(branch_info: Dict[str, Any],
                              integration_branches: List[Tuple[str, Dict[str, Any]]]) -> None:
    """
    Show status of integration branches relative to a feature branch.

    Args:
        branch_info: The feature branch information
        integration_branches: List of (name, branch_info) tuples for integration branches
    """
    if not integration_branches:
        return

    print("\nIntegration branches:")
    for v, br in sorted(integration_branches, key=lambda x: x[0]):
        if br.get('local_branch') in config["ignore"] or br.get('remote_branch') in config["ignore"]:
            continue
        if br.get('ignore'):
            continue

        local_only = not br.get('remote_branch')
        remote_only = not br.get('local_branch')
        display_name = cyan(br['name']) if remote_only else green(br['name'])

        ahead = get_commits_between(v, branch_info.get('local_branch') or branch_info['remote_branch'])
        if not ahead:
            print_widget(True, local_only)
            print(f"merged into {display_name}")
        else:
            print_widget(False, local_only)
            print(f"NOT merged into {display_name} ({pluralize(len(ahead), 'commit')} ahead)")
            if not short:
                show_commits(ahead)


def show_branch_relations(branch_info: Dict[str, Any], all_branches: Dict[str, Dict[str, Any]]) -> None:
    """
    Show how a branch relates to integration/feature branches.

    Args:
        branch_info: Information about the current branch
        all_branches: Dictionary of all branches in the repository
    """
    integration_branches_set = set(config["integration-branches"])

    ibs = []
    fbs = []
    for name, br in all_branches.items():
        if br.get('local_branch') in integration_branches_set or br.get('remote_branch') in integration_branches_set:
            ibs.append((name, br))
        else:
            fbs.append((name, br))

    if branch_info.get('local_branch') in integration_branches_set:
        show_feature_branches(branch_info, fbs)
    else:
        show_integration_branches(branch_info, ibs)


def load_config() -> Dict[str, Any]:
    """
    Load configuration from .git-wtfrc.json file.

    Returns:
        Configuration dictionary with defaults

    Searches up directory tree for config file and merges with defaults.
    """
    config = DEFAULT_CONFIG.copy()
    config_file = find_file(CONFIG_FN)
    if config_file:
        try:
            with open(config_file, 'r') as f:
                loaded_config = json.load(f)
                # Support old nomenclature
                if "versions" in loaded_config and "integration-branches" not in loaded_config:
                    loaded_config["integration-branches"] = loaded_config["versions"]
                config.update(loaded_config)
        except (json.JSONDecodeError, IOError):
            pass  # Use defaults if config file is invalid
    return config


def get_remotes() -> Dict[str, str]:
    """
    Get all git remotes and their URLs.

    Returns:
        Dictionary mapping remote name to URL
    """
    remotes = {}
    remote_config = git_command(["git", "config", "--get-regexp", r"^remote\..*\.url"])
    for line in remote_config.split('\n'):
        if line:
            match = re.match(r'^remote\.(.+?)\.url (.+)$', line)
            if match:
                remotes[match.group(1)] = match.group(2)
    return remotes


def get_tracked_branches(remotes: Dict[str, str]) -> Dict[str, Dict[str, Any]]:
    """
    Get all tracked branches from git config.

    Args:
        remotes: Dictionary of remote names to URLs

    Returns:
        Dictionary mapping branch name to tracking information
    """
    branches: Dict[str, Dict[str, Any]] = {}
    branch_config = git_command(["git", "config", "--get-regexp", "^branch."])

    for line in branch_config.split('\n'):
        if not line:
            continue

        match = re.match(r'branch\.(.*?)\.remote (.+)', line)
        if match:
            name, remote = match.group(1), match.group(2)
            if name not in branches:
                branches[name] = {}
            branches[name]['remote'] = remote
            branches[name]['remote_url'] = remotes.get(remote)

        match = re.match(r'branch\.(.*?)\.merge (?:(?:refs/)?heads/)?(.+)', line)
        if match:
            name, remote_branch = match.group(1), match.group(2)
            if name not in branches:
                branches[name] = {}
            branches[name]['remote_mergepoint'] = remote_branch

    return branches


def get_all_branches(remotes: Dict[str, str], tracked_branches: Dict[str, Dict[str, Any]],
                     all_remotes_flag: bool) -> Tuple[Dict[str, Dict[str, Any]], Dict[str, bool]]:
    """
    Get all local and remote branches.

    Args:
        remotes: Dictionary of remote names
        tracked_branches: Dictionary of tracking branch info
        all_remotes_flag: Whether to include all remotes or just origin

    Returns:
        Tuple of (branches dict, remote_branches set)
    """
    branches = tracked_branches.copy()
    remote_branches: Dict[str, bool] = {}

    show_ref = git_command(["git", "show-ref"])
    for line in show_ref.split('\n'):
        if not line:
            continue

        parts = line.split(' refs/', 1)
        if len(parts) != 2:
            continue
        sha1, ref = parts

        # Local branch
        match = re.match(r'^heads/(.+)$', ref)
        if match:
            name = match.group(1)
            if name == "HEAD":
                continue
            if name not in branches:
                branches[name] = {}
            branches[name]['name'] = name
            branches[name]['local_branch'] = ref

        # Remote branch
        match = re.match(r'^remotes/(.+?)/(.+)$', ref)
        if match:
            remote, name = match.group(1), match.group(2)
            remote_branches[f"{remote}/{name}"] = True
            if name == "HEAD":
                continue

            ignore = not (all_remotes_flag or remote == "origin")

            branch = name
            if name in branches and branches[name].get('remote') == remote:
                pass  # Use existing name
            else:
                name = f"{remote}/{branch}"

            if name not in branches:
                branches[name] = {}
            branches[name]['name'] = name
            branches[name]['remote'] = remote
            branches[name]['remote_branch'] = f"{remote}/{branch}"
            branches[name]['remote_url'] = remotes.get(remote)
            branches[name]['ignore'] = ignore

    return branches, remote_branches


def assemble_remote_refs(branches: Dict[str, Dict[str, Any]],
                         remote_branches: Dict[str, bool]) -> None:
    """
    Link local branches to their remote tracking branches.

    Args:
        branches: Dictionary of branch information (modified in place)
        remote_branches: Set of remote branch names
    """
    for k, b in branches.items():
        if b.get('remote') and b.get('remote_mergepoint'):
            if b['remote'] == ".":
                b['remote_branch'] = b['remote_mergepoint']
            else:
                t = f"{b['remote']}/{b['remote_mergepoint']}"
                if t in remote_branches:  # only if it's still alive
                    b['remote_branch'] = t


def get_current_branch() -> Optional[str]:
    """
    Get the current branch name.

    Returns:
        Current branch name, or None if in detached HEAD state
    """
    try:
        current_ref = git_command(["git", "symbolic-ref", "HEAD"], check=False)
        if current_ref:
            return current_ref.replace('refs/heads/', '', 1)
        return None
    except GitCommandError:
        return None


def check_working_directory_status() -> Tuple[bool, bool]:
    """
    Check if working directory has modifications.

    Returns:
        Tuple of (has_modified_files, has_staged_files)
    """
    modified = git_command(["git", "ls-files", "-m"]) != ""
    uncommitted = git_command(["git", "diff-index", "--cached", "HEAD"]) != ""
    return modified, uncommitted


def parse_args() -> Dict[str, Any]:
    """
    Parse command-line arguments.

    Returns:
        Dictionary of parsed arguments
    """
    args = {
        'verbose': '-v' in sys.argv or '--verbose' in sys.argv,
        'long': '--long' in sys.argv or '-l' in sys.argv,
        'short': '--short' in sys.argv or '-s' in sys.argv,
        'all_remotes': '--all' in sys.argv or '-a' in sys.argv,
        'all_commits': '--all-commits' in sys.argv or '-A' in sys.argv,
        'dump_config': '--dump-config' in sys.argv,
        'show_key': '--key' in sys.argv or '-k' in sys.argv,
        'show_relations': '--relations' in sys.argv or '-r' in sys.argv,
        'show_filename': '--filename' in sys.argv or '-f' in sys.argv,
    }

    # Remove processed arguments
    for flag in ['-v', '--verbose', '--long', '-l', '--short', '-s',
                 '--all', '-a', '--all-commits', '-A', '--dump-config',
                 '--key', '-k', '--relations', '-r', '--filename', '-f']:
        while flag in sys.argv:
            sys.argv.remove(flag)

    # Check for unknown arguments
    remaining_args = [a for a in sys.argv[1:] if a.startswith("--")]
    if remaining_args:
        print(f"Error: unknown argument {remaining_args[0]}.", file=sys.stderr)
        sys.exit(ExitCode.ERROR)

    # Get target branches
    args['targets'] = [arg.replace('heads/', '', 1) for arg in sys.argv[1:]]

    return args


def main() -> int:
    """
    Main entry point for git-wtf.

    Returns:
        Exit code
    """
    global config, use_color, long, short, all_remotes, all_commits, show_filename

    # Check for help
    if "--help" in sys.argv or "-h" in sys.argv:
        print(USAGE)
        return ExitCode.SUCCESS

    # Parse arguments
    args = parse_args()

    # Set global flags
    long = args['long']
    short = args['short']
    all_remotes = args['all_remotes']
    all_commits = args['all_commits']
    show_filename = args['show_filename']

    # Load configuration
    config = load_config()

    # Dump config if requested
    if args['dump_config']:
        print(json.dumps(config, indent=2))
        return ExitCode.SUCCESS

    # Determine color support
    want_color = git_config("color.wtf")
    if not want_color:
        want_color = git_config("color.ui")

    use_color = want_color == "true" or (want_color == "auto" and sys.stdout.isatty())

    # Get repository information
    try:
        remotes = get_remotes()
        tracked_branches = get_tracked_branches(remotes)
        all_branches, remote_branches = get_all_branches(remotes, tracked_branches, all_remotes)
        assemble_remote_refs(all_branches, remote_branches)
    except GitError as e:
        print(f"Error: {e}", file=sys.stderr)
        return ExitCode.GIT_ERROR

    # Determine target branches
    if not args['targets']:
        current = get_current_branch()
        if current is None:
            print("Error: Not on a branch (detached HEAD state)", file=sys.stderr)
            return ExitCode.ERROR
        targets = [current]
        show_dirty = True
    else:
        targets = args['targets']
        show_dirty = False

    # Validate targets
    target_branches = []
    for t in targets:
        if t not in all_branches:
            print(f"Error: can't find branch {t!r}.", file=sys.stderr)
            return ExitCode.ERROR
        target_branches.append(all_branches[t])

    # Show status for each target
    for branch_info in target_branches:
        show_branch_status(branch_info)
        if args['show_relations'] or not branch_info.get('remote_branch'):
            show_branch_relations(branch_info, all_branches)

    # Check working directory status
    if show_dirty:
        modified, uncommitted = check_working_directory_status()

        if args['show_key']:
            print()
            print(KEY)

        if modified or uncommitted:
            print()
        if modified:
            print(f"{red('NOTE')}: working directory contains modified files.")
        if uncommitted:
            print(f"{red('NOTE')}: staging area contains staged but uncommitted files.")
        if modified or uncommitted:
            print()

    return ExitCode.SUCCESS


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print("\nInterrupted", file=sys.stderr)
        sys.exit(ExitCode.ERROR)
    except GitError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(ExitCode.GIT_ERROR)
    except Exception as e:
        print(f"Unexpected error: {e}", file=sys.stderr)
        sys.exit(ExitCode.ERROR)
