#!/usr/bin/env ruby
# encoding: utf-8

require 'tempfile'
require 'tmpdir'
require 'json'
require 'fileutils'
require 'open3'
require 'shellwords'

def get_git_editor
  editor = `git config core.editor`.strip
  editor.empty? ? 'vim' : editor
end

def check_merge_conflict(file)
  output, status = Open3.capture2("git", "ls-files", "-u", "--", file)
  return true unless status.success?
  output.strip.empty?
end

def get_merge_base(ours, theirs)
  # Try octopus merge-base first for criss-cross merges
  base, status = Open3.capture2("git", "merge-base", "--octopus", ours, theirs)
  base = base.strip
  unless status.success?
    base = ""
  end
  if base.empty?
    base, status = Open3.capture2("git", "merge-base", ours, theirs)
    base = status.success? ? base.strip : ""
  end
  base
end

def file_diff_identical?(left, right)
  system("git", "diff", "--no-index", "--quiet", "--", left, right)
  $?.success?
end

def review_resolved_vs_originals(resolved_path, original_ours, original_theirs, original_base, label_prefix = "resolved")
  editor = get_git_editor

  loop do
    ours_same = file_diff_identical?(resolved_path, original_ours)
    theirs_same = file_diff_identical?(resolved_path, original_theirs)
    base_same = file_diff_identical?(resolved_path, original_base)

    puts "\nPost-merge review:"
    puts "1. Diff #{label_prefix} vs original ours#{ours_same ? ' (no difference)' : ''}"
    puts "2. Diff #{label_prefix} vs original theirs#{theirs_same ? ' (no difference)' : ''}"
    puts "3. Diff #{label_prefix} vs original base#{base_same ? ' (no difference)' : ''}"
    puts "4. Accept and continue"
    print "> "
    input = STDIN.gets
    choice = input ? input.strip : '4'

    case choice
    when '1'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_ours, resolved_path)
    when '2'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_theirs, resolved_path)
    when '3'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_base, resolved_path)
    when '4'
      return true
    else
      puts "Invalid choice."
    end
  end
end

def has_write_tree_support?
  output, status = Open3.capture2("git", "merge-tree", "--help")
  status.success? && output.include?("--write-tree")
end

def simulate_merge_with_tree(base, ours, theirs)
  if has_write_tree_support?
    # Use modern --write-tree mode - but need correct syntax
    merged_tree, status = Open3.capture2e("git", "merge-tree", "--write-tree", ours, theirs)
    merged_tree = merged_tree.strip
    success = status.success?

    if success
      # Check if there are differences vs both sides
      system "git", "diff", "--quiet", ours, merged_tree
      has_ours_changes = !$?.success?
      system "git", "diff", "--quiet", theirs, merged_tree
      has_theirs_changes = !$?.success?

      {
        success: true,
        merged_tree: merged_tree,
        has_ours_changes: has_ours_changes,
        has_theirs_changes: has_theirs_changes
      }
    else
      # Parse conflicts from stderr
      {
        success: false,
        conflicts: merged_tree
      }
    end
  else
    # Fall back to traditional merge-tree output parsing
    merge_output = `git merge-tree #{base} #{ours} #{theirs}`

    if merge_output.strip.empty?
      # Clean merge - no output means no conflicts
      { success: true, clean: true }
    else
      # Check if it contains conflict markers
      if merge_output.include?("changed in both") || merge_output.include?("<<<<<<< .our")
        { success: false, merge_output: merge_output }
      else
        # Has changes but clean merge
        { success: true, merge_output: merge_output }
      end
    end
  end
end

def extract_conflict_files(file, json_output = false, emit_output = true)
  if check_merge_conflict(file)
    error_msg = "'#{file}' is not in a merge conflict state."
    if json_output
      puts JSON.generate({error: error_msg})
    else
      puts "Error: #{error_msg}"
    end
    exit 1
  end

  tmpdir = Dir.mktmpdir("git-diff-123-")
  file_theirs = File.join(tmpdir, 'theirs')
  file_ours = File.join(tmpdir, 'ours')
  file_base = File.join(tmpdir, 'base')

  {
    "3" => file_theirs,
    "2" => file_ours,
    "1" => file_base
  }.each do |stage, output_path|
    content, status = Open3.capture2("git", "show", ":#{stage}:#{file}")
    unless status.success?
      puts JSON.generate({error: "Failed to extract stage #{stage} for '#{file}'"}) if json_output
      puts "Error: Failed to extract stage #{stage} for '#{file}'" unless json_output
      exit 1
    end
    File.write(output_path, content)
  end

  if emit_output
    if json_output
      puts JSON.generate({
        tmpdir: tmpdir,
        ours: file_ours,
        base: file_base,
        theirs: file_theirs
      })
    else
      puts "#{tmpdir}:#{file_ours}:#{file_base}:#{file_theirs}"
    end
  end

  {
    tmpdir: tmpdir,
    ours: file_ours,
    base: file_base,
    theirs: file_theirs
  }
end

def run_guided_resolution(file, dry_run = false)
  editor = get_git_editor
  extracted = extract_conflict_files(file, false, false)
  file_ours = extracted[:ours]
  file_base = extracted[:base]
  file_theirs = extracted[:theirs]
  original_ours = File.join(extracted[:tmpdir], "original_ours")
  original_base = File.join(extracted[:tmpdir], "original_base")
  original_theirs = File.join(extracted[:tmpdir], "original_theirs")
  FileUtils.cp(file_ours, original_ours)
  FileUtils.cp(file_base, original_base)
  FileUtils.cp(file_theirs, original_theirs)

  loop do
    puts "
Choose a diff to view for '#{file}':"
    puts "1. Edit Ours vs Base (auto re-merge)"
    puts "2. Edit Theirs vs Base (auto re-merge)"
    puts "3. Edit Theirs vs Ours (auto re-merge)"
    puts "4. Retry without editing"
    puts "q. Quit"
    print "> "
    input = STDIN.gets
    choice = input ? input.strip : 'q'

    should_try_remerge = false

    case choice
    when '1'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_base, file_ours)
      should_try_remerge = true
    when '2'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_base, file_theirs)
      should_try_remerge = true
    when '3'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_theirs, file_ours)
      should_try_remerge = true
    when '4'
      should_try_remerge = true
    when 'q'
      return false
    else
      puts "Invalid choice."
    end

    next unless should_try_remerge

    if remerge_from_files(file, file_ours, file_base, file_theirs, dry_run, false)
      review_resolved_vs_originals(file, original_ours, original_theirs, original_base)
      return true
    end

    puts "\nStill conflicted. Keep editing or quit."
  end
end

def extract_file_at_revision(rev, file, output_path)
  content, status = Open3.capture2("git", "show", "#{rev}:#{file}")
  return false unless status.success?
  File.write(output_path, content)
  true
end

def audit_merge(file, commit, json_output = false)
  parents_line, status = Open3.capture2("git", "rev-list", "--parents", "-n", "1", commit)
  unless status.success?
    msg = "Could not resolve commit '#{commit}'"
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  fields = parents_line.strip.split
  unless fields.length >= 3
    msg = "Commit '#{commit}' is not a merge commit."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  parent1 = fields[1]
  parent2 = fields[2]
  base = get_merge_base(parent1, parent2)
  if base.empty?
    msg = "Could not determine merge base for #{parent1[0..7]} and #{parent2[0..7]}"
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  tmpdir = Dir.mktmpdir("git-diff-123-audit-")
  resolved_path = File.join(tmpdir, "resolved")
  ours_path = File.join(tmpdir, "original_ours")
  theirs_path = File.join(tmpdir, "original_theirs")
  base_path = File.join(tmpdir, "original_base")

  unless extract_file_at_revision(commit, file, resolved_path) &&
         extract_file_at_revision(parent1, file, ours_path) &&
         extract_file_at_revision(parent2, file, theirs_path) &&
         extract_file_at_revision(base, file, base_path)
    msg = "File '#{file}' not available at one or more required revisions."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  _merged_content, _merge_stderr, merge_status = Open3.capture3(
    "git", "merge-file", "-p", ours_path, base_path, theirs_path
  )
  conflict_likely = merge_status.exitstatus == 1

  if json_output
    puts JSON.generate({
      status: "ok",
      commit: commit,
      file: file,
      conflict_likely: conflict_likely,
      resolved: resolved_path,
      original_ours: ours_path,
      original_theirs: theirs_path,
      original_base: base_path
    })
    return true
  end

  puts "Audit merge commit #{commit[0..7]} for '#{file}':"
  puts "Parent1 (ours): #{parent1[0..7]}"
  puts "Parent2 (theirs): #{parent2[0..7]}"
  puts "Base: #{base[0..7]}"
  if conflict_likely
    puts "Conflict likelihood: likely (manual resolution risk worth reviewing)"
  else
    puts "Conflict likelihood: low (clean auto-merge likely)"
  end
  review_resolved_vs_originals(resolved_path, ours_path, theirs_path, base_path, "resolved@#{commit[0..7]}")
  true
end

def remerge_from_files(file, ours_path, base_path, theirs_path, dry_run = false, json_output = false)
  unless File.exist?(ours_path) && File.exist?(base_path) && File.exist?(theirs_path)
    if json_output
      puts JSON.generate({ status: "error", message: "One or more temp files not found" })
    else
      puts "Error: One or more temp files not found"
    end
    return false
  end

  merged_content, merge_stderr, status = Open3.capture3(
    "git", "merge-file", "-p", ours_path, base_path, theirs_path
  )

  if status.exitstatus == 0
    if dry_run
      if json_output
        puts JSON.generate({ status: "dry_run_clean", message: "Clean re-merge available for #{file} (not applied)." })
      else
        puts "Dry run: clean re-merge available for #{file} (not applied)."
      end
      return true
    end

    File.write(file, merged_content)
    system "git", "add", "--", file
    unless $?.success?
      if json_output
        puts JSON.generate({ status: "error", message: "Failed to stage #{file}" })
      else
        puts "Error: Failed to stage #{file}"
      end
      return false
    end

    if json_output
      puts JSON.generate({ status: "applied", message: "Clean re-merge successful! Applied and staged #{file}." })
    else
      puts "Clean re-merge successful! Applied and staged #{file}."
    end
    return true
  end

  if status.exitstatus == 1
    if json_output
      puts JSON.generate({
        status: "still_conflicted",
        message: "Re-merge still has conflicts after manual edits for #{file}.",
        merged_preview: merged_content
      })
    else
      puts "Re-merge still has conflicts after manual edits for #{file}."
      puts "Update your edited ours/theirs files and try again."
      puts "\nMerged preview with conflict markers:"
      puts "-" * 50
      puts merged_content
      puts "-" * 50
    end
    return false
  end

  if json_output
    puts JSON.generate({ status: "error", message: "git merge-file failed for #{file}", stderr: merge_stderr.strip })
  else
    puts "Error: git merge-file failed for #{file}."
    puts merge_stderr unless merge_stderr.strip.empty?
  end
  false
end

def simulate_merge_for_conflict_file(file)
  # Get the commits involved in the conflict
  # Use HEAD and MERGE_HEAD for the actual commits
  ours_commit = `git rev-parse HEAD`.strip
  theirs_commit = `git rev-parse MERGE_HEAD 2>/dev/null`.strip

  if theirs_commit.empty?
    puts "Error: Not currently in a merge state (MERGE_HEAD not found)"
    return false
  end

  base_commit = get_merge_base(ours_commit, theirs_commit)

  if ours_commit.empty? || theirs_commit.empty? || base_commit.empty?
    puts "Error: Could not determine commit references for conflict in #{file}"
    return false
  end

  puts "Merge simulation for '#{file}':"
  puts "Base: #{base_commit[0..7]}"
  puts "Ours: #{ours_commit[0..7]}"
  puts "Theirs: #{theirs_commit[0..7]}"
  puts

  # Simulate the merge
  result = simulate_merge_with_tree(base_commit, ours_commit, theirs_commit)

  if result[:success]
    puts "✅ This conflict should merge cleanly with proper 3-way merge!"
    if result[:merged_tree]
      puts "Merged tree: #{result[:merged_tree][0..7]}"

      # Show what the clean merge would produce
      merged_content, show_status = Open3.capture2("git", "show", "#{result[:merged_tree]}:#{file}")
      if show_status.success?
        puts "\nClean merged content preview:"
        puts "─" * 50
        puts merged_content
        puts "─" * 50
        puts "\nWould you like to apply this clean merge? (y/N)"
        input = STDIN.gets
        choice = input ? input.strip.downcase : 'n'

        if choice == 'y' || choice == 'yes'
          File.write(file, merged_content)
          system "git", "add", "--", file
          puts "Clean merge applied and staged!"
          return true
        end
      end
    end
  else
    puts "❌ Merge has genuine conflicts that need manual resolution:"
    puts result[:conflicts] if result[:conflicts]
    puts result[:merge_output] if result[:merge_output]
  end

  false
end

def main
  json_output = ARGV.delete('--json')
  dry_run = ARGV.delete('--dry-run')
  no_guided = ARGV.delete('--no-guided')

  if ARGV[0] == '--extract'
    file = ARGV[1]
    unless file
      puts("USAGE: #{File.basename __FILE__} --extract [--json] FILE")
      exit 0
    end
    interactive_extract = !no_guided && STDIN.tty? && STDOUT.tty?
    if interactive_extract
      puts "Interactive mode: entering guided conflict resolution."
      run_guided_resolution(file, dry_run)
    else
      extract_conflict_files(file, json_output)
    end
    return
  end

  if ARGV[0] == '--remerge'
    file, ours_path, base_path, theirs_path = ARGV[1], ARGV[2], ARGV[3], ARGV[4]
    unless file && ours_path && base_path && theirs_path
      puts("USAGE: #{File.basename __FILE__} --remerge FILE OURS_PATH BASE_PATH THEIRS_PATH")
      exit 0
    end
    success = remerge_from_files(file, ours_path, base_path, theirs_path, dry_run, json_output)
    exit(success ? 0 : 1)
  end

  if ARGV[0] == '--simulate'
    file = ARGV[1]
    unless file
      puts("USAGE: #{File.basename __FILE__} --simulate FILE")
      exit 0
    end

    if check_merge_conflict(file)
      puts "Error: '#{file}' is not in a merge conflict state."
      exit 1
    end

    simulate_merge_for_conflict_file(file)
    return
  end

  if ARGV[0] == '--audit-merge'
    commit = ARGV[1]
    file = ARGV[2]
    unless commit && file
      puts("USAGE: #{File.basename __FILE__} --audit-merge COMMIT FILE [--json]")
      exit 0
    end
    success = audit_merge(file, commit, json_output)
    exit(success ? 0 : 1)
  end

  file = ARGV.shift
  if !file || file == '--help' || file == '-h'
    puts("USAGE: #{File.basename __FILE__} [--dry-run] [--json] [--no-guided] FILE")
    puts("       #{File.basename __FILE__} --extract [--json] [--no-guided] FILE")
    puts("       #{File.basename __FILE__} [--json] [--dry-run] --remerge FILE OURS_PATH BASE_PATH THEIRS_PATH")
    puts("       #{File.basename __FILE__} --simulate FILE")
    puts("       #{File.basename __FILE__} --audit-merge COMMIT FILE [--json]")
    puts("")
    puts("Enhanced 3-way merge conflict resolution")
    puts("--extract: Write stage 2/1/3 (ours/base/theirs) to temp files")
    puts("--remerge: Re-merge edited ours/base/theirs files and stage on success")
    puts("--simulate: Check if conflict can be resolved cleanly")
    puts("--dry-run: Show what would happen without writing/staging")
    puts("--json: Emit machine-readable JSON output")
    puts("--no-guided: Disable interactive extract mode")
    puts("")
    puts("JSON statuses for --remerge: applied, dry_run_clean, still_conflicted, error")
    exit 0
  end

  if check_merge_conflict(file)
    puts "Error: '#{file}' is not in a merge conflict state."
    exit 1
  end

  # First try simulation to see if it's a false conflict
  puts "Checking if this is a false conflict that should merge cleanly..."
  if simulate_merge_for_conflict_file(file)
    return # Successfully resolved with clean merge
  end

  # Fall back to manual resolution workflow
  puts "\nProceeding with manual 3-way merge resolution..."
  run_guided_resolution(file, dry_run)
end

main
