#!/usr/bin/env ruby
# encoding: utf-8

require 'tempfile'
require 'tmpdir'
require 'json'
require 'fileutils'
require 'open3'
require 'shellwords'
require 'set'

$color_mode = "auto"

def parse_color_mode!(args)
  mode = "auto"
  kept = []
  i = 0
  while i < args.length
    arg = args[i]
    if arg == "--no-color"
      mode = "never"
    elsif arg.start_with?("--color=")
      value = arg.split("=", 2)[1]
      unless %w[auto always never].include?(value)
        puts "Error: invalid --color value '#{value}' (use auto|always|never)"
        exit 1
      end
      mode = value
    elsif arg == "--color"
      value = args[i + 1]
      if value.nil? || value.start_with?("--") || !%w[auto always never].include?(value)
        puts "Error: --color requires one of auto|always|never"
        exit 1
      end
      mode = value
      i += 1
    else
      kept << arg
    end
    i += 1
  end
  args.replace(kept)
  $color_mode = mode
end

def color_enabled?
  return true if $color_mode == "always"
  return false if $color_mode == "never"
  return false if ENV["NO_COLOR"]
  STDOUT.tty? && ENV.fetch("TERM", "dumb") != "dumb"
end

def colorize(text, code)
  return text unless color_enabled?
  "\e[#{code}m#{text}\e[0m"
end

def status_presentation(status)
  case status
  when "likely_conflict"
    { label: "likely_conflict", marker: "+", color: 31 } # red
  when "likely_clean"
    { label: "likely_clean", marker: "-", color: 32 } # green
  else
    { label: "non_comparable(skipped)", marker: "~", color: 33 } # yellow
  end
end

def get_git_editor
  editor = `git config core.editor`.strip
  editor.empty? ? 'vim' : editor
end

def check_merge_conflict(file)
  output, status = Open3.capture2("git", "ls-files", "-u", "--", file)
  return true unless status.success?
  output.strip.empty?
end

def has_conflict_entries?(file)
  output, status = Open3.capture2("git", "ls-files", "-u", "--", file)
  return false unless status.success?
  !output.strip.empty?
end

def conflict_stages_for_file(file)
  output, status = Open3.capture2("git", "ls-files", "-u", "--", file)
  return [] unless status.success?

  stages = []
  output.each_line do |line|
    fields = line.split
    next if fields.length < 4
    stage = fields[2]
    stages << stage if %w[1 2 3].include?(stage)
  end
  stages.uniq
end

def rev_parse(ref)
  out, _err, status = Open3.capture3("git", "rev-parse", "--verify", ref)
  return nil unless status.success?
  value = out.strip
  value.empty? ? nil : value
end

def integration_head_ref
  %w[MERGE_HEAD CHERRY_PICK_HEAD REVERT_HEAD REBASE_HEAD].each do |ref|
    sha = rev_parse(ref)
    return [ref, sha] unless sha.nil?
  end
  nil
end

def integration_in_progress?
  !integration_head_ref.nil?
end

# Returns a non-nil String (SHA or "") so callers may use .empty? safely.
def integration_base_revision(ours_rev, integration_ref_name, theirs_rev)
  case integration_ref_name
  when "CHERRY_PICK_HEAD", "REBASE_HEAD"
    # These flows replay a single commit. Use the picked commit's first parent as base
    # so unrelated earlier branch history is not pulled into "theirs".
    # NOTE: for rebase of merge commits (REBASE_HEAD with 2+ parents), ^1 is a best-effort
    # approximation of replay base.
    base = rev_parse("#{theirs_rev}^1")
    return base unless base.nil? || base.empty?
  when "REVERT_HEAD"
    # Revert applies a commit in reverse, so the reverted commit itself is the base side.
    return theirs_rev
  end
  get_merge_base(ours_rev, theirs_rev)
end

def get_merge_base(ours, theirs)
  # Try octopus merge-base first for criss-cross merges
  base, status = Open3.capture2("git", "merge-base", "--octopus", ours, theirs)
  base = base.strip
  unless status.success?
    base = ""
  end
  if base.empty?
    base, status = Open3.capture2("git", "merge-base", ours, theirs)
    base = status.success? ? base.strip : ""
  end
  base
end

# Keyed by "parent1_sha:parent2_sha" → Set of conflicting filenames (or nil on error).
MERGE_TREE_CACHE = {}

# Runs `git merge-tree --write-tree --name-only` once per unique (parent1, parent2) pair.
# Lets git merge-tree compute its own merge base (including virtual base for criss-cross).
# Returns:
#   Set[]            — clean merge (no conflicts)
#   Set["a.txt", …] — conflict, with the listed files having conflict markers
#   nil              — git internal error (exit 2+), treat as non_comparable
def merge_tree_conflicts_for_commit(parent1, parent2)
  cache_key = "#{parent1}:#{parent2}"
  return MERGE_TREE_CACHE[cache_key] if MERGE_TREE_CACHE.key?(cache_key)

  out, _err, status = Open3.capture3(
    "git", "merge-tree", "--write-tree", "--name-only",
    parent1, parent2
  )

  result = case status.exitstatus
           when 0
             Set.new
           when 1
             # stdout with --name-only on conflict (Git >= 2.38):
             #   line 0: <tree-sha>
             #   lines 1..N-1: conflicting filenames (one per line)
             #   line N: blank line (separator before diagnostic messages)
             # take_while stops at the blank so diagnostic lines are not collected.
             lines = out.lines.map(&:chomp)
             filenames = lines.drop(1).take_while { |l| !l.empty? }
             Set.new(filenames)
           else
             nil
           end

  MERGE_TREE_CACHE[cache_key] = result
  result
end

def blob_content_at_revision(rev, file)
  content, _stderr, status = Open3.capture3("git", "show", "#{rev}:#{file}")
  return nil unless status.success?
  content
end

def file_diff_identical?(left, right)
  system("git", "diff", "--no-index", "--quiet", "--", left, right)
  $?.success?
end

def review_resolved_vs_originals(resolved_path, original_ours, original_theirs, original_base, label_prefix = "resolved")
  editor = get_git_editor

  loop do
    ours_same = file_diff_identical?(resolved_path, original_ours)
    theirs_same = file_diff_identical?(resolved_path, original_theirs)
    base_same = file_diff_identical?(resolved_path, original_base)

    puts "\nPost-merge review:"
    puts "1. Diff #{label_prefix} vs original ours#{ours_same ? ' (no difference)' : ''}"
    puts "2. Diff #{label_prefix} vs original theirs#{theirs_same ? ' (no difference)' : ''}"
    puts "3. Diff #{label_prefix} vs original base#{base_same ? ' (no difference)' : ''}"
    puts "4. Accept and continue"
    print "> "
    input = STDIN.gets
    choice = input ? input.strip : '4'

    case choice
    when '1'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_ours, resolved_path)
    when '2'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_theirs, resolved_path)
    when '3'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_base, resolved_path)
    when '4'
      return true
    else
      puts "Invalid choice."
    end
  end
end

def extract_conflict_files(file, json_output = false, emit_output = true)
  has_conflict_stages = has_conflict_entries?(file)
  if !has_conflict_stages && !integration_in_progress?
    error_msg = "'#{file}' is not in a merge conflict state."
    if json_output
      puts JSON.generate({error: error_msg})
    else
      puts "Error: #{error_msg}"
    end
    exit 1
  end

  tmpdir = Dir.mktmpdir("git-resolve-conflict-")
  file_theirs = File.join(tmpdir, 'theirs')
  file_ours = File.join(tmpdir, 'ours')
  file_base = File.join(tmpdir, 'base')
  if has_conflict_stages
    present_stages = conflict_stages_for_file(file)

    {
      "3" => file_theirs,
      "2" => file_ours,
      "1" => file_base
    }.each do |stage, output_path|
      unless present_stages.include?(stage)
        # Some valid conflicts (e.g., modify/delete, add/add) do not include every stage.
        # Represent missing sides as empty files so comparison/remerge still works.
        File.write(output_path, "")
        next
      end

      content, status = Open3.capture2("git", "show", ":#{stage}:#{file}")
      unless status.success?
        puts JSON.generate({error: "Failed to extract stage #{stage} for '#{file}'"}) if json_output
        puts "Error: Failed to extract stage #{stage} for '#{file}'" unless json_output
        exit 1
      end

      File.write(output_path, content)
    end
  else
    ours_rev = rev_parse("HEAD")
    integration_ref = integration_head_ref
    integration_ref_name = integration_ref ? integration_ref[0] : nil
    theirs_rev = integration_ref ? integration_ref[1] : nil
    if ours_rev.nil? || theirs_rev.nil?
      error_msg = "Could not determine active merge revisions for '#{file}'."
      if json_output
        puts JSON.generate({error: error_msg})
      else
        puts "Error: #{error_msg}"
      end
      exit 1
    end
    base_rev = integration_base_revision(ours_rev, integration_ref_name, theirs_rev)
    if base_rev.empty?
      error_msg = "Could not determine merge base for active merge."
      if json_output
        puts JSON.generate({error: error_msg})
      else
        puts "Error: #{error_msg}"
      end
      exit 1
    end

    ours_content = blob_content_at_revision(ours_rev, file)
    base_content = blob_content_at_revision(base_rev, file)
    theirs_content = blob_content_at_revision(theirs_rev, file)
    if integration_ref_name == "REVERT_HEAD"
      # Model revert as reversing the target commit: base is the target commit tree,
      # and "theirs" is its first parent.
      theirs_content = blob_content_at_revision("#{theirs_rev}^1", file)
    end
    if ours_content.nil? && base_content.nil? && theirs_content.nil?
      error_msg = "File '#{file}' is not available in active merge revisions."
      if json_output
        puts JSON.generate({error: error_msg})
      else
        puts "Error: #{error_msg}"
      end
      exit 1
    end

    File.write(file_ours, ours_content.nil? ? "" : ours_content)
    File.write(file_base, base_content.nil? ? "" : base_content)
    File.write(file_theirs, theirs_content.nil? ? "" : theirs_content)
  end

  if emit_output
    if json_output
      puts JSON.generate({
        tmpdir: tmpdir,
        ours: file_ours,
        base: file_base,
        theirs: file_theirs
      })
    else
      puts "#{tmpdir}:#{file_ours}:#{file_base}:#{file_theirs}"
    end
  end

  {
    tmpdir: tmpdir,
    ours: file_ours,
    base: file_base,
    theirs: file_theirs
  }
end

def run_guided_resolution(file, dry_run = false)
  editor = get_git_editor
  extracted = extract_conflict_files(file, false, false)
  file_ours = extracted[:ours]
  file_base = extracted[:base]
  file_theirs = extracted[:theirs]
  original_ours = File.join(extracted[:tmpdir], "original_ours")
  original_base = File.join(extracted[:tmpdir], "original_base")
  original_theirs = File.join(extracted[:tmpdir], "original_theirs")
  FileUtils.cp(file_ours, original_ours)
  FileUtils.cp(file_base, original_base)
  FileUtils.cp(file_theirs, original_theirs)

  print_conflict_summary(file)

  loop do
    puts "
Choose a diff to view for '#{file}':"
    puts "1. Edit Ours vs Base (auto re-merge)"
    puts "2. Edit Theirs vs Base (auto re-merge)"
    puts "3. Edit Theirs vs Ours (auto re-merge)"
    puts "4. Retry without editing"
    puts "q. Quit"
    print "> "
    input = STDIN.gets
    choice = input ? input.strip : 'q'

    should_try_remerge = false

    case choice
    when '1'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_base, file_ours)
      should_try_remerge = true
    when '2'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_base, file_theirs)
      should_try_remerge = true
    when '3'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_theirs, file_ours)
      should_try_remerge = true
    when '4'
      should_try_remerge = true
    when 'q'
      return false
    else
      puts "Invalid choice."
    end

    next unless should_try_remerge

    if remerge_from_files(file, file_ours, file_base, file_theirs, dry_run, false)
      review_resolved_vs_originals(file, original_ours, original_theirs, original_base)
      return true
    end

    puts "\nStill conflicted. Keep editing or quit."
  end
end

def parse_conflict_hunks(file)
  lines = File.readlines(file, encoding: "utf-8")
  hunks = []
  i = 0
  while i < lines.length
    if lines[i].start_with?("<<<<<<< ")
      start_i = i
      mid_i = nil
      end_i = nil
      j = i + 1
      while j < lines.length
        if mid_i.nil? && lines[j].start_with?("=======")
          mid_i = j
        elsif lines[j].start_with?(">>>>>>> ")
          end_i = j
          break
        end
        j += 1
      end
      break unless mid_i && end_i

      context = nil
      k = start_i - 1
      while k >= 0
        stripped = lines[k].strip
        unless stripped.empty? || stripped.start_with?("<<<<<<<", "=======", ">>>>>>>")
          context = stripped
          break
        end
        k -= 1
      end

      hunks << {
        start_line: start_i + 1,
        ours_lines: mid_i - start_i - 1,
        theirs_lines: end_i - mid_i - 1,
        context: context
      }
      i = end_i + 1
      next
    end
    i += 1
  end
  hunks
end

def print_conflict_summary(file)
  hunks = parse_conflict_hunks(file)
  return if hunks.empty?

  max_side_lines = hunks.map { |h| [h[:ours_lines], h[:theirs_lines]].max }.max || 0
  risk = if hunks.length >= 5 || max_side_lines >= 20
           "high"
         elsif hunks.length >= 2 || max_side_lines >= 8
           "medium"
         else
           "low"
         end

  risk_color = risk == "high" ? 31 : (risk == "medium" ? 33 : 32)
  puts "\nConflict summary for '#{file}':"
  puts "  hunks=#{hunks.length}  risk=#{colorize(risk, risk_color)}"
  puts "  preview:"
  hunks.first(3).each do |h|
    context = h[:context] ? " | context: #{h[:context]}" : ""
    puts "    - line #{h[:start_line]} (ours=#{h[:ours_lines]}, theirs=#{h[:theirs_lines]})#{context}"
  end
  puts "    ... (#{hunks.length - 3} more)" if hunks.length > 3
end

def extract_file_at_revision(rev, file, output_path)
  content, _stderr, status = Open3.capture3("git", "show", "#{rev}:#{file}")
  return false unless status.success?
  File.write(output_path, content)
  true
end

def audit_merge(file, commit, json_output = false)
  parents_line, _stderr, status = Open3.capture3("git", "rev-list", "--parents", "-n", "1", commit)
  unless status.success?
    msg = "Could not resolve commit '#{commit}'"
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  fields = parents_line.strip.split
  unless fields.length >= 3
    msg = "Commit '#{commit}' is not a merge commit."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  if fields.length > 3
    msg = "Commit '#{commit}' has #{fields.length - 1} parents; audit mode only supports 2-parent merge commits."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  parents = get_merge_commit_parents(commit)
  parent1, parent2 = parents
  base = get_merge_base(parent1, parent2)
  if base.empty?
    msg = "Could not determine merge base for #{parent1[0..7]} and #{parent2[0..7]}"
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  analysis = conflict_likely_for_merge_file(commit, file)
  if analysis["conflict_likely"].nil?
    msg = "Cannot determine conflict likelihood for '#{file}' (#{analysis['reason']})."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end
  conflict_likely = analysis["conflict_likely"]

  tmpdir = Dir.mktmpdir("git-resolve-conflict-audit-")
  resolved_path = File.join(tmpdir, "resolved")
  ours_path = File.join(tmpdir, "original_ours")
  theirs_path = File.join(tmpdir, "original_theirs")
  base_path = File.join(tmpdir, "original_base")

  unless extract_file_at_revision(commit, file, resolved_path)
    msg = "File '#{file}' not available at merge commit '#{commit}'."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  ours_content = blob_content_at_revision(parent1, file)
  theirs_content = blob_content_at_revision(parent2, file)
  base_content = blob_content_at_revision(base, file)
  File.write(ours_path, ours_content.nil? ? "" : ours_content)
  File.write(theirs_path, theirs_content.nil? ? "" : theirs_content)
  File.write(base_path, base_content.nil? ? "" : base_content)

  if json_output
    puts JSON.generate({
      status: "ok",
      commit: commit,
      file: file,
      conflict_likely: conflict_likely,
      reason: analysis["reason"],
      resolved: resolved_path,
      original_ours: ours_path,
      original_theirs: theirs_path,
      original_base: base_path
    })
    return true
  end

  puts "Audit merge commit #{commit[0..7]} for '#{file}' (#{analysis['reason']}):"
  puts "Parent1 (ours): #{parent1[0..7]}"
  puts "Parent2 (theirs): #{parent2[0..7]}"
  puts "Base: #{base[0..7]}"
  if conflict_likely
    puts "Conflict likelihood: likely (manual resolution risk worth reviewing)"
  else
    puts "Conflict likelihood: low (clean auto-merge likely)"
  end
  review_resolved_vs_originals(resolved_path, ours_path, theirs_path, base_path, "resolved@#{commit[0..7]}")
  true
end

def get_merge_commit_parents(commit)
  parents_line, _stderr, status = Open3.capture3("git", "rev-list", "--parents", "-n", "1", commit)
  return nil unless status.success?
  fields = parents_line.strip.split
  return nil if fields.length < 3
  fields[1..]
end

def changed_files_for_merge(commit, path_filter = nil)
  cmd = ["git", "diff-tree", "-m", "--no-commit-id", "--name-only", "-r", commit]
  cmd += ["--", path_filter] if path_filter && !path_filter.empty?
  output, status = Open3.capture2(*cmd)
  return [] unless status.success?
  output.lines.map(&:strip).reject(&:empty?).uniq
end

def conflict_likely_for_merge_file(commit, file)
  parents = get_merge_commit_parents(commit)
  return { "conflict_likely" => nil, "status" => "non_comparable", "reason" => "not_a_merge_commit" } unless parents
  if parents.length != 2
    return { "conflict_likely" => nil, "status" => "non_comparable", "reason" => "unsupported_multi_parent_merge" }
  end

  parent1, parent2 = parents
  conflict_set = merge_tree_conflicts_for_commit(parent1, parent2)
  if conflict_set.nil?
    return { "conflict_likely" => nil, "status" => "non_comparable", "reason" => "merge_tree_error" }
  end

  if conflict_set.include?(file)
    { "conflict_likely" => true, "status" => "likely_conflict", "reason" => "merge_tree_conflict" }
  else
    { "conflict_likely" => false, "status" => "likely_clean", "reason" => "merge_tree_clean" }
  end
end

def build_find_log_command(log_filters, path_filter = nil)
  filters = log_filters.dup
  pathspec = []
  if (idx = filters.index("--"))
    pathspec = filters[(idx + 1)..] || []
    filters = filters[0...idx]
  end

  cmd = ["git", "log", "--merges", "--pretty=format:%H"] + filters + ["HEAD"]
  final_paths = []
  final_paths.concat(pathspec)
  final_paths << path_filter if path_filter && !path_filter.empty?
  cmd += ["--"] + final_paths if final_paths.any?
  cmd
end

def find_merges(path_filter = nil, log_filters = [], json_output = false)
  output, _stderr, status = Open3.capture3(*build_find_log_command(log_filters, path_filter))
  unless status.success?
    msg = "Failed to list merge commits from current branch."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  commits = output.lines.map(&:strip).reject(&:empty?)
  results = []
  commits.each do |commit|
    files = changed_files_for_merge(commit, path_filter)
    analyses = files.map { |f| conflict_likely_for_merge_file(commit, f) }
    analyzed = analyses.count { |a| !a["conflict_likely"].nil? }
    likely_conflicts = analyses.count { |a| a["conflict_likely"] == true }
    non_comparable = analyses.count { |a| a["status"] == "non_comparable" }
    conflict_likely = analyzed > 0 ? (likely_conflicts > 0) : nil
    results << {
      "commit" => commit,
      "conflict_likely" => conflict_likely,
      "files_analyzed" => analyzed,
      "files_non_comparable" => non_comparable
    }
  end

  if json_output
    puts JSON.generate({ status: "ok", merges: results })
    return true
  end

  if results.empty?
    puts "No merge commits found for current branch and filters."
    return false
  end

  puts "Merge conflict-likelihood scan (HEAD history):"
  results.each do |r|
    if r["conflict_likely"].nil?
      label = "status_unknown(non_comparable_only)"
      marker = colorize("~", 33)
      label = colorize(label, 33)
    else
      label = r["conflict_likely"] ? "likely_had_conflicts" : "likely_clean"
      marker = r["conflict_likely"] ? "+" : "-"
      marker = colorize(marker, r["conflict_likely"] ? 31 : 32)
      label = colorize(label, r["conflict_likely"] ? 31 : 32)
    end
    puts "#{marker} #{r['commit'][0..11]}  #{label}  files_analyzed=#{r['files_analyzed']}  non_comparable(skipped)=#{r['files_non_comparable']}"
  end
  true
end

def find_merge_commit_files(commit, path_filter = nil, json_output = false)
  parents = get_merge_commit_parents(commit)
  unless parents
    msg = "Commit '#{commit}' is not a merge commit."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  files = changed_files_for_merge(commit, path_filter)
  results = files.map do |file|
    analysis = conflict_likely_for_merge_file(commit, file)
    {
      "file" => file,
      "conflict_likely" => analysis["conflict_likely"],
      "status" => analysis["status"],
      "reason" => analysis["reason"]
    }
  end

  if json_output
    puts JSON.generate({ status: "ok", commit: commit, files: results })
    return true
  end

  puts "File-level conflict likelihood for merge #{commit[0..11]}:"
  if results.empty?
    puts "(no files matched)"
    return true
  end

  grouped = {
    "likely_conflict" => [],
    "likely_clean" => [],
    "non_comparable" => []
  }
  results.each { |r| grouped[r["status"]] << r }

  printed_any = false
  grouped.each do |status, entries|
    next if entries.empty?
    style = status_presentation(status)
    puts "" if printed_any
    header = "#{style[:marker]} #{style[:label]}:"
    puts colorize(header, style[:color])
    entries.each do |r|
      item_marker = colorize(style[:marker], style[:color])
      detail = r["reason"] ? " (#{r['reason']})" : ""
      puts "  #{item_marker} #{r['file']}#{detail}"
    end
    printed_any = true
  end
  true
end

def remerge_from_files(file, ours_path, base_path, theirs_path, dry_run = false, json_output = false)
  unless File.exist?(ours_path) && File.exist?(base_path) && File.exist?(theirs_path)
    if json_output
      puts JSON.generate({ status: "error", message: "One or more temp files not found" })
    else
      puts "Error: One or more temp files not found"
    end
    return false
  end

  merged_content, merge_stderr, status = Open3.capture3(
    "git", "merge-file", "-p", ours_path, base_path, theirs_path
  )

  if status.exitstatus == 0
    if dry_run
      if json_output
        puts JSON.generate({ status: "dry_run_clean", message: "Clean re-merge available for #{file} (not applied)." })
      else
        puts "Dry run: clean re-merge available for #{file} (not applied)."
      end
      return true
    end

    File.write(file, merged_content)
    system "git", "add", "--", file
    unless $?.success?
      if json_output
        puts JSON.generate({ status: "error", message: "Failed to stage #{file}" })
      else
        puts "Error: Failed to stage #{file}"
      end
      return false
    end

    if json_output
      puts JSON.generate({ status: "applied", message: "Clean re-merge successful! Applied and staged #{file}." })
    else
      puts "Clean re-merge successful! Applied and staged #{file}."
    end
    return true
  end

  if status.exitstatus && status.exitstatus > 0
    if json_output
      puts JSON.generate({
        status: "still_conflicted",
        message: "Re-merge still has conflicts after manual edits for #{file}.",
        merged_preview: merged_content
      })
    else
      puts "Re-merge still has conflicts after manual edits for #{file}."
      puts "Update your edited ours/theirs files and try again."
      puts "\nMerged preview with conflict markers:"
      puts "-" * 50
      puts merged_content
      puts "-" * 50
    end
    return false
  end

  if json_output
    puts JSON.generate({ status: "error", message: "git merge-file failed for #{file}", stderr: merge_stderr.strip })
  else
    puts "Error: git merge-file failed for #{file}."
    puts merge_stderr unless merge_stderr.strip.empty?
  end
  false
end

def main
  args = ARGV.dup
  literal_path_mode = (args[0] == "--")
  parse_color_mode!(args)

  json_output = !literal_path_mode && args.delete('--json')
  dry_run = !literal_path_mode && args.delete('--dry-run')

  if args[0] == '--tool-extract'
    file = args[1]
    unless file
      puts("USAGE: #{File.basename __FILE__} --tool-extract FILE")
      exit 1
    end
    extract_conflict_files(file, true)
    return
  end

  if args[0] == '--tool-remerge'
    file, ours_path, base_path, theirs_path = args[1], args[2], args[3], args[4]
    unless file && ours_path && base_path && theirs_path
      puts("USAGE: #{File.basename __FILE__} --tool-remerge FILE OURS_PATH BASE_PATH THEIRS_PATH")
      exit 1
    end
    success = remerge_from_files(file, ours_path, base_path, theirs_path, dry_run, true)
    exit(success ? 0 : 1)
  end

  if args.include?('--find')
    log_filters = []
    if (sep_index = args.index("--"))
      log_filters = args[(sep_index + 1)..] || []
      args = args[0...sep_index]
    end

    args.delete('--find')
    commit = nil
    if (commit_index = args.index('--commit'))
      if commit_index + 1 >= args.length || args[commit_index + 1].start_with?('--')
        puts("USAGE: #{File.basename __FILE__} --find [FILE] [--commit COMMIT] [--json] [-- <git-log-filters>]")
        exit 1
      end
      commit = args[commit_index + 1]
      args.slice!(commit_index, 2)
    end

    path_filter = nil
    unless args.empty?
      if args.length == 1
        path_filter = args[0]
      else
        puts("USAGE: #{File.basename __FILE__} --find [FILE] [--commit COMMIT] [--json] [-- <git-log-filters>]")
        exit 1
      end
    end

    success = if commit
      find_merge_commit_files(commit, path_filter, json_output)
    else
      find_merges(path_filter, log_filters, json_output)
    end
    exit(success ? 0 : 1)
  end

  if args[0] == '--commit'
    commit_args = args[1..]
    commit = nil
    file = nil
    if commit_args.length == 1
      commit = commit_args[0]
      success = find_merge_commit_files(commit, nil, json_output)
      exit(success ? 0 : 1)
    elsif commit_args.length == 2
      commit = commit_args[0]
      file = commit_args[1]
    else
      puts("USAGE: #{File.basename __FILE__} --commit COMMIT [FILE] [--json]")
      exit 1
    end
    success = audit_merge(file, commit, json_output)
    exit(success ? 0 : 1)
  end

  args.shift if literal_path_mode

  if args.empty? || (!literal_path_mode && args.length == 1 && (args[0] == '--help' || args[0] == '-h'))
    puts("USAGE: #{File.basename __FILE__} [--dry-run] [--color MODE|--no-color] FILE")
    puts("       #{File.basename __FILE__} [--color MODE|--no-color] --commit COMMIT [FILE] [--json]")
    puts("       #{File.basename __FILE__} [--color MODE|--no-color] --find [FILE] [--commit COMMIT] [--json] [-- <git-log-filters>]")
    puts("")
    puts("Enhanced 3-way merge conflict resolution")
    puts("FILE: Guided conflict resolution for current working tree")
    puts("--dry-run: Retry merge checks without writing/staging resolved file")
    puts("--commit: Audit a merge commit (summary mode without FILE, deep audit with FILE)")
    puts("--find: Find likely-conflicted merge commits on current branch")
    puts("--json: Emit machine-readable JSON output")
    puts("--color: Colorized output mode: auto|always|never")
    puts("--no-color: Disable colored output")
    exit 0
  end
  file = args.shift

  if !File.exist?(file) && !has_conflict_entries?(file)
    puts "Error: '#{file}' not found in working tree and not in conflict index."
    exit 1
  end

  if check_merge_conflict(file) && !integration_in_progress?
    puts "Error: '#{file}' is not in a merge conflict state."
    exit 1
  end

  puts "Starting guided 3-way merge resolution..."
  success = run_guided_resolution(file, dry_run)
  unless success
    puts "Aborted without applying resolution."
    exit 1
  end
end

main
