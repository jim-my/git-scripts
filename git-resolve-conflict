#!/usr/bin/env ruby
# encoding: utf-8

require 'tempfile'
require 'tmpdir'
require 'json'
require 'fileutils'
require 'open3'
require 'shellwords'

def get_git_editor
  editor = `git config core.editor`.strip
  editor.empty? ? 'vim' : editor
end

def check_merge_conflict(file)
  output, status = Open3.capture2("git", "ls-files", "-u", "--", file)
  return true unless status.success?
  output.strip.empty?
end

def has_conflict_entries?(file)
  output, status = Open3.capture2("git", "ls-files", "-u", "--", file)
  return false unless status.success?
  !output.strip.empty?
end

def get_merge_base(ours, theirs)
  # Try octopus merge-base first for criss-cross merges
  base, status = Open3.capture2("git", "merge-base", "--octopus", ours, theirs)
  base = base.strip
  unless status.success?
    base = ""
  end
  if base.empty?
    base, status = Open3.capture2("git", "merge-base", ours, theirs)
    base = status.success? ? base.strip : ""
  end
  base
end

def file_diff_identical?(left, right)
  system("git", "diff", "--no-index", "--quiet", "--", left, right)
  $?.success?
end

def review_resolved_vs_originals(resolved_path, original_ours, original_theirs, original_base, label_prefix = "resolved")
  editor = get_git_editor

  loop do
    ours_same = file_diff_identical?(resolved_path, original_ours)
    theirs_same = file_diff_identical?(resolved_path, original_theirs)
    base_same = file_diff_identical?(resolved_path, original_base)

    puts "\nPost-merge review:"
    puts "1. Diff #{label_prefix} vs original ours#{ours_same ? ' (no difference)' : ''}"
    puts "2. Diff #{label_prefix} vs original theirs#{theirs_same ? ' (no difference)' : ''}"
    puts "3. Diff #{label_prefix} vs original base#{base_same ? ' (no difference)' : ''}"
    puts "4. Accept and continue"
    print "> "
    input = STDIN.gets
    choice = input ? input.strip : '4'

    case choice
    when '1'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_ours, resolved_path)
    when '2'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_theirs, resolved_path)
    when '3'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", original_base, resolved_path)
    when '4'
      return true
    else
      puts "Invalid choice."
    end
  end
end

def extract_conflict_files(file, json_output = false, emit_output = true)
  if check_merge_conflict(file)
    error_msg = "'#{file}' is not in a merge conflict state."
    if json_output
      puts JSON.generate({error: error_msg})
    else
      puts "Error: #{error_msg}"
    end
    exit 1
  end

  tmpdir = Dir.mktmpdir("git-resolve-conflict-")
  file_theirs = File.join(tmpdir, 'theirs')
  file_ours = File.join(tmpdir, 'ours')
  file_base = File.join(tmpdir, 'base')

  {
    "3" => file_theirs,
    "2" => file_ours,
    "1" => file_base
  }.each do |stage, output_path|
    content, status = Open3.capture2("git", "show", ":#{stage}:#{file}")
    unless status.success?
      puts JSON.generate({error: "Failed to extract stage #{stage} for '#{file}'"}) if json_output
      puts "Error: Failed to extract stage #{stage} for '#{file}'" unless json_output
      exit 1
    end
    File.write(output_path, content)
  end

  if emit_output
    if json_output
      puts JSON.generate({
        tmpdir: tmpdir,
        ours: file_ours,
        base: file_base,
        theirs: file_theirs
      })
    else
      puts "#{tmpdir}:#{file_ours}:#{file_base}:#{file_theirs}"
    end
  end

  {
    tmpdir: tmpdir,
    ours: file_ours,
    base: file_base,
    theirs: file_theirs
  }
end

def run_guided_resolution(file, dry_run = false)
  editor = get_git_editor
  extracted = extract_conflict_files(file, false, false)
  file_ours = extracted[:ours]
  file_base = extracted[:base]
  file_theirs = extracted[:theirs]
  original_ours = File.join(extracted[:tmpdir], "original_ours")
  original_base = File.join(extracted[:tmpdir], "original_base")
  original_theirs = File.join(extracted[:tmpdir], "original_theirs")
  FileUtils.cp(file_ours, original_ours)
  FileUtils.cp(file_base, original_base)
  FileUtils.cp(file_theirs, original_theirs)

  loop do
    puts "
Choose a diff to view for '#{file}':"
    puts "1. Edit Ours vs Base (auto re-merge)"
    puts "2. Edit Theirs vs Base (auto re-merge)"
    puts "3. Edit Theirs vs Ours (auto re-merge)"
    puts "4. Retry without editing"
    puts "q. Quit"
    print "> "
    input = STDIN.gets
    choice = input ? input.strip : 'q'

    should_try_remerge = false

    case choice
    when '1'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_base, file_ours)
      should_try_remerge = true
    when '2'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_base, file_theirs)
      should_try_remerge = true
    when '3'
      system(*Shellwords.split(editor), "-c", "set diffopt+=iwhite", "-d", file_theirs, file_ours)
      should_try_remerge = true
    when '4'
      should_try_remerge = true
    when 'q'
      return false
    else
      puts "Invalid choice."
    end

    next unless should_try_remerge

    if remerge_from_files(file, file_ours, file_base, file_theirs, dry_run, false)
      review_resolved_vs_originals(file, original_ours, original_theirs, original_base)
      return true
    end

    puts "\nStill conflicted. Keep editing or quit."
  end
end

def extract_file_at_revision(rev, file, output_path)
  content, _stderr, status = Open3.capture3("git", "show", "#{rev}:#{file}")
  return false unless status.success?
  File.write(output_path, content)
  true
end

def audit_merge(file, commit, json_output = false)
  parents_line, _stderr, status = Open3.capture3("git", "rev-list", "--parents", "-n", "1", commit)
  unless status.success?
    msg = "Could not resolve commit '#{commit}'"
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  fields = parents_line.strip.split
  unless fields.length >= 3
    msg = "Commit '#{commit}' is not a merge commit."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  parent1 = fields[1]
  parent2 = fields[2]
  base = get_merge_base(parent1, parent2)
  if base.empty?
    msg = "Could not determine merge base for #{parent1[0..7]} and #{parent2[0..7]}"
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  tmpdir = Dir.mktmpdir("git-resolve-conflict-audit-")
  resolved_path = File.join(tmpdir, "resolved")
  ours_path = File.join(tmpdir, "original_ours")
  theirs_path = File.join(tmpdir, "original_theirs")
  base_path = File.join(tmpdir, "original_base")

  unless extract_file_at_revision(commit, file, resolved_path) &&
         extract_file_at_revision(parent1, file, ours_path) &&
         extract_file_at_revision(parent2, file, theirs_path) &&
         extract_file_at_revision(base, file, base_path)
    msg = "File '#{file}' not available at one or more required revisions."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  _merged_content, _merge_stderr, merge_status = Open3.capture3(
    "git", "merge-file", "-p", ours_path, base_path, theirs_path
  )
  conflict_likely = merge_status.exitstatus == 1

  if json_output
    puts JSON.generate({
      status: "ok",
      commit: commit,
      file: file,
      conflict_likely: conflict_likely,
      resolved: resolved_path,
      original_ours: ours_path,
      original_theirs: theirs_path,
      original_base: base_path
    })
    return true
  end

  puts "Audit merge commit #{commit[0..7]} for '#{file}':"
  puts "Parent1 (ours): #{parent1[0..7]}"
  puts "Parent2 (theirs): #{parent2[0..7]}"
  puts "Base: #{base[0..7]}"
  if conflict_likely
    puts "Conflict likelihood: likely (manual resolution risk worth reviewing)"
  else
    puts "Conflict likelihood: low (clean auto-merge likely)"
  end
  review_resolved_vs_originals(resolved_path, ours_path, theirs_path, base_path, "resolved@#{commit[0..7]}")
  true
end

def get_merge_commit_parents(commit)
  parents_line, _stderr, status = Open3.capture3("git", "rev-list", "--parents", "-n", "1", commit)
  return nil unless status.success?
  fields = parents_line.strip.split
  return nil if fields.length < 3
  [fields[1], fields[2]]
end

def changed_files_for_merge(commit, path_filter = nil)
  cmd = ["git", "diff-tree", "-m", "--no-commit-id", "--name-only", "-r", commit]
  cmd += ["--", path_filter] if path_filter && !path_filter.empty?
  output, status = Open3.capture2(*cmd)
  return [] unless status.success?
  output.lines.map(&:strip).reject(&:empty?).uniq
end

def conflict_likely_for_merge_file(commit, file)
  parents = get_merge_commit_parents(commit)
  return nil unless parents
  parent1, parent2 = parents
  base = get_merge_base(parent1, parent2)
  return nil if base.empty?

  Dir.mktmpdir("git-resolve-conflict-find-") do |tmpdir|
    ours_path = File.join(tmpdir, "ours")
    theirs_path = File.join(tmpdir, "theirs")
    base_path = File.join(tmpdir, "base")

    return nil unless extract_file_at_revision(parent1, file, ours_path)
    return nil unless extract_file_at_revision(parent2, file, theirs_path)
    return nil unless extract_file_at_revision(base, file, base_path)

    _out, _err, status = Open3.capture3("git", "merge-file", "-p", ours_path, base_path, theirs_path)
    return true if status.exitstatus == 1
    return false if status.exitstatus == 0
  end

  nil
end

def build_find_log_command(log_filters, path_filter = nil)
  filters = log_filters.dup
  pathspec = []
  if (idx = filters.index("--"))
    pathspec = filters[(idx + 1)..] || []
    filters = filters[0...idx]
  end

  cmd = ["git", "log", "--merges", "--pretty=format:%H"] + filters + ["HEAD"]
  final_paths = []
  final_paths.concat(pathspec)
  final_paths << path_filter if path_filter && !path_filter.empty?
  cmd += ["--"] + final_paths if final_paths.any?
  cmd
end

def find_merges(path_filter = nil, log_filters = [], json_output = false)
  output, status = Open3.capture2(*build_find_log_command(log_filters, path_filter))
  unless status.success?
    msg = "Failed to list merge commits from current branch."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  commits = output.lines.map(&:strip).reject(&:empty?)
  results = []
  commits.each do |commit|
    files = changed_files_for_merge(commit, path_filter)
    flags = files.map { |f| conflict_likely_for_merge_file(commit, f) }.compact
    conflict_likely = !flags.empty? && flags.any?
    results << {
      "commit" => commit,
      "conflict_likely" => conflict_likely,
      "files_analyzed" => flags.length
    }
  end

  if json_output
    puts JSON.generate({ status: "ok", merges: results })
    return true
  end

  if results.empty?
    puts "No merge commits found for current branch and filters."
    return false
  end

  puts "Merge conflict-likelihood scan (HEAD history):"
  results.each do |r|
    label = r["conflict_likely"] ? "likely_had_conflicts" : "likely_clean"
    puts "#{r['commit'][0..11]}  #{label}  files_analyzed=#{r['files_analyzed']}"
  end
  true
end

def find_merge_commit_files(commit, path_filter = nil, json_output = false)
  parents = get_merge_commit_parents(commit)
  unless parents
    msg = "Commit '#{commit}' is not a merge commit."
    if json_output
      puts JSON.generate({ status: "error", message: msg })
    else
      puts "Error: #{msg}"
    end
    return false
  end

  files = changed_files_for_merge(commit, path_filter)
  results = files.map do |file|
    {
      "file" => file,
      "conflict_likely" => conflict_likely_for_merge_file(commit, file)
    }
  end

  if json_output
    puts JSON.generate({ status: "ok", commit: commit, files: results })
    return true
  end

  puts "File-level conflict likelihood for merge #{commit[0..11]}:"
  if results.empty?
    puts "(no files matched)"
    return true
  end
  results.each do |r|
    verdict = r["conflict_likely"] == true ? "likely_conflict" : (r["conflict_likely"] == false ? "likely_clean" : "unknown")
    puts "#{verdict}  #{r['file']}"
  end
  true
end

def remerge_from_files(file, ours_path, base_path, theirs_path, dry_run = false, json_output = false)
  unless File.exist?(ours_path) && File.exist?(base_path) && File.exist?(theirs_path)
    if json_output
      puts JSON.generate({ status: "error", message: "One or more temp files not found" })
    else
      puts "Error: One or more temp files not found"
    end
    return false
  end

  merged_content, merge_stderr, status = Open3.capture3(
    "git", "merge-file", "-p", ours_path, base_path, theirs_path
  )

  if status.exitstatus == 0
    if dry_run
      if json_output
        puts JSON.generate({ status: "dry_run_clean", message: "Clean re-merge available for #{file} (not applied)." })
      else
        puts "Dry run: clean re-merge available for #{file} (not applied)."
      end
      return true
    end

    File.write(file, merged_content)
    system "git", "add", "--", file
    unless $?.success?
      if json_output
        puts JSON.generate({ status: "error", message: "Failed to stage #{file}" })
      else
        puts "Error: Failed to stage #{file}"
      end
      return false
    end

    if json_output
      puts JSON.generate({ status: "applied", message: "Clean re-merge successful! Applied and staged #{file}." })
    else
      puts "Clean re-merge successful! Applied and staged #{file}."
    end
    return true
  end

  if status.exitstatus == 1
    if json_output
      puts JSON.generate({
        status: "still_conflicted",
        message: "Re-merge still has conflicts after manual edits for #{file}.",
        merged_preview: merged_content
      })
    else
      puts "Re-merge still has conflicts after manual edits for #{file}."
      puts "Update your edited ours/theirs files and try again."
      puts "\nMerged preview with conflict markers:"
      puts "-" * 50
      puts merged_content
      puts "-" * 50
    end
    return false
  end

  if json_output
    puts JSON.generate({ status: "error", message: "git merge-file failed for #{file}", stderr: merge_stderr.strip })
  else
    puts "Error: git merge-file failed for #{file}."
    puts merge_stderr unless merge_stderr.strip.empty?
  end
  false
end

def main
  args = ARGV.dup
  log_filters = []
  if (sep_index = args.index("--"))
    log_filters = args[(sep_index + 1)..] || []
    args = args[0...sep_index]
  end

  json_output = args.delete('--json')
  dry_run = args.delete('--dry-run')

  if args[0] == '--tool-extract'
    file = args[1]
    unless file
      puts("USAGE: #{File.basename __FILE__} --tool-extract FILE")
      exit 0
    end
    extract_conflict_files(file, true)
    return
  end

  if args[0] == '--tool-remerge'
    file, ours_path, base_path, theirs_path = args[1], args[2], args[3], args[4]
    unless file && ours_path && base_path && theirs_path
      puts("USAGE: #{File.basename __FILE__} --tool-remerge FILE OURS_PATH BASE_PATH THEIRS_PATH")
      exit 0
    end
    success = remerge_from_files(file, ours_path, base_path, theirs_path, dry_run, true)
    exit(success ? 0 : 1)
  end

  if args.include?('--find')
    args.delete('--find')
    commit = nil
    if (commit_index = args.index('--commit'))
      if commit_index + 1 >= args.length || args[commit_index + 1].start_with?('--')
        puts("USAGE: #{File.basename __FILE__} --find [FILE] [--commit COMMIT] [--json] [-- <git-log-filters>]")
        exit 0
      end
      commit = args[commit_index + 1]
      args.slice!(commit_index, 2)
    end

    path_filter = nil
    unless args.empty?
      if args.length == 1
        path_filter = args[0]
      else
        puts("USAGE: #{File.basename __FILE__} --find [FILE] [--commit COMMIT] [--json] [-- <git-log-filters>]")
        exit 0
      end
    end

    success = if commit
      find_merge_commit_files(commit, path_filter, json_output)
    else
      find_merges(path_filter, log_filters, json_output)
    end
    exit(success ? 0 : 1)
  end

  if args[0] == '--commit'
    commit_args = args[1..]
    commit = nil
    file = nil
    if commit_args.length == 1
      commit = commit_args[0]
      success = find_merge_commit_files(commit, nil, json_output)
      exit(success ? 0 : 1)
    elsif commit_args.length == 2
      commit = commit_args[0]
      file = commit_args[1]
    else
      puts("USAGE: #{File.basename __FILE__} --commit COMMIT [FILE] [--json]")
      exit 0
    end
    success = audit_merge(file, commit, json_output)
    exit(success ? 0 : 1)
  end

  file = args.shift
  if !file || file == '--help' || file == '-h'
    puts("USAGE: #{File.basename __FILE__} [--dry-run] FILE")
    puts("       #{File.basename __FILE__} --commit COMMIT [FILE] [--json]")
    puts("       #{File.basename __FILE__} --find [FILE] [--commit COMMIT] [--json] [-- <git-log-filters>]")
    puts("")
    puts("Enhanced 3-way merge conflict resolution")
    puts("FILE: Guided conflict resolution for current working tree")
    puts("--dry-run: Retry merge checks without writing/staging resolved file")
    puts("--commit: Audit a merge commit (summary mode without FILE, deep audit with FILE)")
    puts("--find: Find likely-conflicted merge commits on current branch")
    puts("--json: Emit machine-readable JSON output")
    exit 0
  end

  if !File.exist?(file) && !has_conflict_entries?(file)
    puts "Error: '#{file}' not found in working tree and not in conflict index."
    exit 1
  end

  if check_merge_conflict(file)
    puts "Error: '#{file}' is not in a merge conflict state."
    exit 1
  end

  puts "Starting guided 3-way merge resolution..."
  run_guided_resolution(file, dry_run)
end

main
